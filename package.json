{
  "name": "@bartaxyz/react-tree-list",
  "version": "0.6.0",
  "description": "Tree list UI component for React",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o .out",
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "prepare": "simple-git-hooks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bartaxyz/react-tree-list.git"
  },
  "keywords": [
    "tree",
    "list",
    "ui",
    "react"
  ],
  "author": "Ondřej Bárta (@bartaxyz)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bartaxyz/react-tree-list/issues"
  },
  "homepage": "https://github.com/bartaxyz/react-tree-list#readme",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/lodash": "^4.14.182",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@types/styled-components": "^5.1.1",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/theming": "^8.6.18",
    "storybook": "^8.6.18",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "simple-git-hooks": "^2.11.1",
    "jsdom": "^25.0.1",
    "oxlint": "^0.15.0",
    "prettier": "2.6.2",
    "pretty-quick": "^3.1.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": ">=16",
    "react-dom": ">=16"
  },
  "ignoredDependencies": [
    "husky"
  ],
  "simple-git-hooks": {
    "pre-commit": "npx pretty-quick --staged"
  },
  "dependencies": {
    "lodash": "4.17.21",
    "polished": "4.2.2",
    "styled-components": "5.3.5"
  }
}
